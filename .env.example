# Polymarket Live Trading Credentials
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Your MetaMask private key (hex string, without 0x prefix)
# To export: MetaMask -> Account Details -> Show Private Key
POLYMARKET_PRIVATE_KEY=your_private_key_here

# Your wallet address (0x...)
POLYMARKET_WALLET=0xYOUR_WALLET_ADDRESS

# Set to "true" to log orders without executing (paper mode)
# Set to "false" to place real orders with real money
DRY_RUN=true

# Polygon RPC for on-chain claiming of winnings
POLYGON_RPC=https://polygon-bor-rpc.publicnode.com
